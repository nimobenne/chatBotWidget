OPENAI_API_KEY=
# Admin dashboard login password
ADMIN_PASSWORD=
# Secret used to sign owner/admin session tokens (required in production)
OWNER_AUTH_SECRET=
# Secret used to sign widget tokens (required in production — blocks all widget requests if missing)
WIDGET_SIGNING_SECRET=
# Data store mode: "supabase" for production, "json" for local dev
DATA_STORE=supabase
# Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# Email (Resend - https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=Bookings <onboarding@resend.dev>
# Alert emails (operator notifications)
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=alerts@your-domain.com
# Site URL for OAuth callbacks
NEXT_PUBLIC_SITE_URL=https://chat-bot-widget-two.vercel.app
